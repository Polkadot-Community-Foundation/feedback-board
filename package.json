{
  "name": "feedback-board",
  "version": "0.1.0",
  "private": true,
  "description": "Experimental proof-of-concept: a decentralized sticky-note board on Polkadot. Code developed and published by Parity.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 3000 --strictPort",
    "build:frontend": "tsc -b && vite build",
    "build:contracts": "cdm build",
    "deploy": "cdm deploy -n w3s",
    "deploy:w3s": "cdm deploy -n w3s",
    "deploy:frontend:summit": "polkadot-app-deploy --env summit --mnemonic \"$MNEMONIC\" --config ./polkadot-app-deploy.config.ts --js-merkle --no-transfer-to-signedin-user ./dist feedback.dot",
    "publish:playground": "tsx scripts/publish-to-playground.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@parity/bulletin-sdk": "^0.3.0",
    "@parity/product-sdk-cloud-storage": "^0.6.0",
    "@parity/product-sdk-keys": "^0.3.6",
    "@novasamatech/host-api": "^0.8.4",
    "@novasamatech/host-api-wrapper": "^0.8.4",
    "@parity/product-sdk": "^0.9.0",
    "@parity/product-sdk-address": "^0.1.1",
    "@parity/product-sdk-contracts": "^0.7.0",
    "@parity/product-sdk-descriptors": "^0.6.1",
    "@parity/product-sdk-tx": "^0.2.7",
    "@polkadot-api/ws-provider": "^0.9.0",
    "multiformats": "^13.4.2",
    "polkadot-api": "^2.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
